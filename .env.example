# =============================================================================
# Fraud AI Streaming -- Environment Variables
# =============================================================================
# Copy to .env and fill in values:  cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# -- MySQL --
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_USER=fraud_user
MYSQL_PASSWORD=change_me_strong_password
MYSQL_DATABASE=fraud_db

# -- Kafka --
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# -- ksqlDB --
KSQLDB_URL=http://ksqldb-server:8088

# -- Azure OpenAI --
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
LLM_ENABLED=true

# -- Scoring thresholds --
SCORE_THRESHOLD_FRAUD=0.8
SCORE_THRESHOLD_REVIEW=0.3

# -- Retraining --
RETRAIN_FEEDBACK_THRESHOLD=100
RETRAIN_CHECK_INTERVAL_SECS=300

# -- A/B Testing --
AB_MAX_TRAFFIC_SPLIT=0.5
AB_MIN_SAMPLE_SIZE=500

# -- Producer --
PRODUCER_INTERVAL_MIN=0.1
PRODUCER_INTERVAL_MAX=1.0
